# Generated by xdev — Laravel (Octane/Swoole) + MariaDB + Redis + Adminer.
# Project: {{.ProjectSlug}}   App: {{.AppSlug}}
#
# On first start the app container bootstraps a fresh Laravel install via the
# mounted _/init.sh (composer create-project + Octane + key:generate + migrate),
# then serves with Swoole. Your Laravel code lives in the bind-mounted app/ dir.
# DB/Redis persist under _volumes/ (bind-mounts, bizepp format).
services:
  app:
    image: docker.io/leyume/swoole:2.0.0-dev
    container_name: {{.ProjectSlug}}_{{.AppSlug}}_app
    restart: unless-stopped
    command: ["sh", "/init.sh"]
    depends_on:
      - db
      - redis
    environment:
      APP_ENV: local
      DB_CONNECTION: mysql
      DB_HOST: db
      DB_PORT: 3306
      DB_DATABASE: laravel
      DB_USERNAME: laravel
      DB_PASSWORD: secret
      REDIS_HOST: redis
    volumes:
      - ../app:/var/www/html
      - ./init.sh:/init.sh:ro
    ports:
      - "{{.HostPort}}:8000"
{{- if .HasLimits}}
    deploy:
      resources:
        limits:
{{- if .CPULimit}}
          cpus: "{{.CPUStr}}"
{{- end}}
{{- if .MemLimit}}
          memory: {{.MemStr}}
{{- end}}
{{- end}}
    networks:
      - internal
      - projectnet

  db:
    image: docker.io/leyume/mariadb
    container_name: {{.ProjectSlug}}_{{.AppSlug}}_db
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: laravel
      MYSQL_USER: laravel
      MYSQL_PASSWORD: secret
    volumes:
      - ../_volumes/mysql:/var/lib/mysql
      - ./db/my.cnf:/etc/mysql/conf.d/my.cnf:ro
    networks:
      - internal

  redis:
    image: docker.io/library/redis:7-alpine
    container_name: {{.ProjectSlug}}_{{.AppSlug}}_redis
    restart: unless-stopped
    volumes:
      - ../_volumes/redis:/data
    networks:
      - internal

  adminer:
    image: docker.io/library/adminer
    container_name: {{.ProjectSlug}}_{{.AppSlug}}_adminer
    restart: unless-stopped
    depends_on:
      - db
    environment:
      ADMINER_DEFAULT_SERVER: db
    volumes:
      - ./db/adminer.css:/var/www/html/adminer.css:ro
    ports:
      - "{{.AdminerPort}}:8080"
    networks:
      - internal

# Per-project shared network (created by xdev) plus a private internal network
# for app<->db/redis/adminer traffic.
networks:
  internal:
  projectnet:
    name: {{.NetworkName}}
    external: true
