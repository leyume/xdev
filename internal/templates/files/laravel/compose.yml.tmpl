# Generated by xdev — Laravel on Octane/Swoole + MariaDB + Redis.
# Project: {{.ProjectSlug}}   App: {{.AppSlug}}
#
# Modeled on the bizepp sample. Put your Laravel application in the bind-mounted
# app/ directory; the Swoole image serves it via `php artisan octane:start` once
# config/octane.php is present (otherwise the container idles, waiting for code).
services:
  app:
    image: docker.io/leyume/swoole:2.0.0-dev
    container_name: {{.ProjectSlug}}_{{.AppSlug}}_app
    restart: unless-stopped
    depends_on:
      - db
      - redis
    environment:
      APP_ENV: local
      DB_HOST: db
      DB_DATABASE: laravel
      DB_USERNAME: laravel
      DB_PASSWORD: secret
      REDIS_HOST: redis
    volumes:
      - ../app:/var/www/html
    ports:
      - "{{.HostPort}}:8000"
{{- if .HasLimits}}
    deploy:
      resources:
        limits:
{{- if .CPULimit}}
          cpus: "{{.CPUStr}}"
{{- end}}
{{- if .MemLimit}}
          memory: {{.MemStr}}
{{- end}}
{{- end}}
    networks:
      - internal
      - projectnet

  db:
    image: docker.io/leyume/mariadb
    container_name: {{.ProjectSlug}}_{{.AppSlug}}_db
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: laravel
      MYSQL_USER: laravel
      MYSQL_PASSWORD: secret
    volumes:
      - db_data:/var/lib/mysql
    networks:
      - internal

  redis:
    image: docker.io/library/redis:7-alpine
    container_name: {{.ProjectSlug}}_{{.AppSlug}}_redis
    restart: unless-stopped
    volumes:
      - redis_data:/data
    networks:
      - internal

volumes:
  db_data:
  redis_data:

networks:
  internal:
  projectnet:
    name: {{.NetworkName}}
    external: true
