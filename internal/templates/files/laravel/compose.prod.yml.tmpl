# Generated by xdev — Laravel PRODUCTION stack (selected when the project's
# environment is "prod"). Ported from the bizepp compose.prod.yml.
# Project: {{.ProjectSlug}}   App: {{.AppSlug}}
#
# Uses the hardened Swoole prod image; app code is mounted read-only with
# writable storage/cache carved out. Run `composer install --no-dev` and build
# assets BEFORE deploying — do not run composer in production.
services:
  app:
    image: docker.io/leyume/swoole:2.0.0-prod
    container_name: {{.ProjectSlug}}_{{.AppSlug}}_app
    restart: unless-stopped
    depends_on:
      - db
      - redis
    environment:
      APP_ENV: production
      DB_HOST: db
      DB_DATABASE: laravel
      DB_USERNAME: laravel
      DB_PASSWORD: ${DB_PASSWORD:-secret}
      REDIS_HOST: redis
    volumes:
      - ../app:/var/www/html:ro
      - storage:/var/www/html/storage
      - cache:/var/www/html/bootstrap/cache
    ports:
      - "{{.HostPort}}:8000"
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://127.0.0.1:8000/up"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
    deploy:
      resources:
        limits:
          cpus: "{{if .CPULimit}}{{.CPUStr}}{{else}}2.0{{end}}"
          memory: {{if .MemLimit}}{{.MemStr}}{{else}}1g{{end}}
        reservations:
          memory: 256m
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    networks:
      - internal
      - projectnet

  db:
    image: docker.io/leyume/mariadb
    container_name: {{.ProjectSlug}}_{{.AppSlug}}_db
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: ${DB_ROOT_PASSWORD:-root}
      MYSQL_DATABASE: laravel
      MYSQL_USER: laravel
      MYSQL_PASSWORD: ${DB_PASSWORD:-secret}
    volumes:
      - db_data:/var/lib/mysql
    networks:
      - internal

  redis:
    image: docker.io/library/redis:7-alpine
    container_name: {{.ProjectSlug}}_{{.AppSlug}}_redis
    restart: unless-stopped
    command: ["redis-server", "--appendonly", "yes", "--maxmemory", "256mb", "--maxmemory-policy", "allkeys-lru"]
    volumes:
      - redis_data:/data
    networks:
      - internal

volumes:
  db_data:
  redis_data:
  storage:
  cache:

networks:
  internal:
  projectnet:
    name: {{.NetworkName}}
    external: true
