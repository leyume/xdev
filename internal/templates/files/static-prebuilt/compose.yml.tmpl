# Generated by xdev — regenerated when the app changes; avoid editing by hand.
# Project: {{.ProjectSlug}}   App: {{.AppSlug}}   Type: {{.AppType}}
#
# Serves the bind-mounted app/ directory (your built dist/) with Caddy's static
# file server. In Phase 2 the host port below is replaced by routing through the
# shared Caddy proxy with a real .test domain + SSL.
services:
  web:
    image: docker.io/library/caddy:2-alpine
    container_name: {{.ProjectSlug}}_{{.AppSlug}}_web
    restart: unless-stopped
    command: caddy file-server --root /srv --listen :80 --browse
    volumes:
      - ../app:/srv:ro
    ports:
      - "{{.HostPort}}:80"
{{- if .HasLimits}}
    deploy:
      resources:
        limits:
{{- if .CPULimit}}
          cpus: "{{.CPUStr}}"
{{- end}}
{{- if .MemLimit}}
          memory: {{.MemStr}}
{{- end}}
{{- end}}
    networks:
      - projectnet

# Shared per-project network (created by xdev) so apps in a project can reach
# each other by service name. Declared external so each app's compose joins the
# same network rather than creating its own.
networks:
  projectnet:
    name: {{.NetworkName}}
    external: true
