# Generated by xdev — WordPress + MariaDB.
# Project: {{.ProjectSlug}}   App: {{.AppSlug}}
#
# WordPress core + your themes/plugins live in the bind-mounted app/ directory
# (the official image populates it on first run). Database data persists in a
# named volume. The reverse proxy fronts the web service on its host port.
services:
  web:
    image: docker.io/library/wordpress:6-php8.3-apache
    container_name: {{.ProjectSlug}}_{{.AppSlug}}_web
    restart: unless-stopped
    depends_on:
      - db
    environment:
      WORDPRESS_DB_HOST: db
      WORDPRESS_DB_USER: wp
      WORDPRESS_DB_PASSWORD: wp_secret
      WORDPRESS_DB_NAME: wordpress
    volumes:
      - ../app:/var/www/html
    ports:
      - "{{.HostPort}}:80"
{{- if .HasLimits}}
    deploy:
      resources:
        limits:
{{- if .CPULimit}}
          cpus: "{{.CPUStr}}"
{{- end}}
{{- if .MemLimit}}
          memory: {{.MemStr}}
{{- end}}
{{- end}}
    networks:
      - internal
      - projectnet

  db:
    image: docker.io/library/mariadb:11
    container_name: {{.ProjectSlug}}_{{.AppSlug}}_db
    restart: unless-stopped
    environment:
      MARIADB_DATABASE: wordpress
      MARIADB_USER: wp
      MARIADB_PASSWORD: wp_secret
      MARIADB_ROOT_PASSWORD: root_secret
    volumes:
      - db_data:/var/lib/mysql
    networks:
      - internal

volumes:
  db_data:

networks:
  # internal: private to this app (web <-> db by service name).
  internal:
  # projectnet: shared across the project so other apps can reach this one by
  # container name. Created by xdev; declared external here.
  projectnet:
    name: {{.NetworkName}}
    external: true
