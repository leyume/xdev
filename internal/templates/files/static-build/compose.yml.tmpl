# Generated by xdev — Static app, build/dev mode (Vite dev server with HMR).
# Project: {{.ProjectSlug}}   App: {{.AppSlug}}
#
# Runs `npm install` then the Vite dev server against the source in app/. This
# is the "before build" workflow (live reload). For the "after build" workflow,
# use a static-prebuilt app pointed at your dist/ output.
services:
  web:
    image: docker.io/library/node:20-alpine
    container_name: {{.ProjectSlug}}_{{.AppSlug}}_web
    restart: unless-stopped
    working_dir: /app
    command: sh -c "npm install && npm run dev -- --host 0.0.0.0 --port 80"
    volumes:
      - ../app:/app
      # Keep node_modules in a volume so it doesn't fight the host bind mount.
      - node_modules:/app/node_modules
    ports:
      - "{{.HostPort}}:80"
{{- if .HasLimits}}
    deploy:
      resources:
        limits:
{{- if .CPULimit}}
          cpus: "{{.CPUStr}}"
{{- end}}
{{- if .MemLimit}}
          memory: {{.MemStr}}
{{- end}}
{{- end}}
    networks:
      - projectnet

volumes:
  node_modules:

networks:
  projectnet:
    name: {{.NetworkName}}
    external: true
