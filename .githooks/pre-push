#!/usr/bin/env bash
# Local pre-push safety gate: build, vet, and test before code leaves the
# machine. This is a fast correctness check only — it does NOT build or publish
# release binaries (that's GitHub Actions' job on a version tag; see
# .github/workflows/release.yml).
#
# Enable once with:  make hooks   (or: git config core.hooksPath .githooks)
# Bypass in a pinch with:  git push --no-verify
set -euo pipefail

# Homebrew Go on macOS dev machines isn't always on git's PATH.
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

if ! command -v go >/dev/null 2>&1; then
  echo "pre-push: go not found on PATH — skipping gate" >&2
  exit 0
fi

echo "pre-push: go build ./..."
go build ./...
echo "pre-push: go vet ./..."
go vet ./...
echo "pre-push: go test ./..."
go test ./...
echo "pre-push: ok"
