# xdev configuration — the canonical reference for every XDEV_* variable.
#
# The service manager (systemd on Linux, launchd on macOS) loads this file and
# passes it to xdev as the environment, so xdev can be configured entirely from
# here with no flags. Precedence is: explicit flag > env var > built-in default.
#
# install.sh writes a populated copy to:
#   Linux:  /etc/xdev/xdev.env            (0640, root)
#   macOS:  ~/Library/Application Support/xdev/xdev.env
#
# Edit, then restart the service (systemctl restart xdev / launchctl kickstart).

# --- core --------------------------------------------------------------------
# Data directory: holds xdev.db (sqlite) and backups/. Persists across upgrades.
XDEV_DATA=/var/lib/xdev
# Generated per-project / per-app compose stacks live here.
XDEV_PROJECTS=/var/lib/xdev/projects
# Web UI listen address — keep it bound to loopback and reach it via SSH tunnel.
XDEV_ADDR=127.0.0.1:7331
# Set the Secure flag on cookies. Enable when the UI is served over HTTPS.
XDEV_SECURE=true

# --- engine ------------------------------------------------------------------
# Container engine: docker | podman. Leave unset to auto-detect.
XDEV_ENGINE=docker

# --- proxy & TLS -------------------------------------------------------------
# Supervise Caddy as a child process (true), or run/manage Caddy yourself (false).
XDEV_CADDY=true
# Caddy admin API address (loopback).
XDEV_CADDY_ADMIN=127.0.0.1:2019
# Public ports for proxied sites. Use 8443/8080 for sudo-free local dev.
XDEV_HTTPS_PORT=443
XDEV_HTTP_PORT=80
# Contact email for Let's Encrypt (production domains). Required for prod ACME.
XDEV_ACME_EMAIL=ops@example.com
# Validity of locally-issued (.test/.localhost) TLS certs; keep under ~8000h.
XDEV_LOCAL_CERT_LIFETIME=2160h

# --- hosts (servers: off) ----------------------------------------------------
# Hosts file to manage local domains in (local dev only).
XDEV_HOSTS_FILE=/etc/hosts
# Auto-write local domains into the hosts file. Turn OFF on a real server —
# production sites resolve via real DNS.
XDEV_MANAGE_HOSTS=false
